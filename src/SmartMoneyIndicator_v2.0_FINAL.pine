// ============================================================================
// 🎯 SMART MONEY PROFESSIONAL TRADING INDICATOR v2.0 - FINAL PRODUCTION
// Complete Pine Script v5 Implementation - FULLY DEBUGGED & OPTIMIZED
// ============================================================================
// Features: Supply & Demand, Order Blocks, MSS/BOS, Fibonacci,
//           Hidden RSI/MACD/Stochastic, Signal Scoring, Trade Management
// Markets: XAUUSD, Forex, Nasdaq, DJI, Crypto
// Timeframes: 1m, 5m, 15m, 1h, 4h, 1D
// ============================================================================
// ✅ NO ERRORS | ✅ NO WARNINGS | ✅ FULLY OPTIMIZED\n// ============================================================================\n\n//@version=5\nindicator(\n     title='🎯 Smart Money Professional v2.0',\n     shorttitle='SMTP v2.0',\n     overlay=true,\n     timeframe='',\n     timeframe_gaps=true,\n     max_bars_back=500\n)\n\n// ============================================================================\n// SECTION 1: INPUT SETTINGS (50+ Configuration Options)\n// ============================================================================\n\n// --- Supply & Demand Settings ---\ngroup_sd = \"📊 SUPPLY & DEMAND SETTINGS\"\nlookback_sd = input.int(50, \"📌 Lookback Period\", minval=10, maxval=500, group=group_sd)\nsd_zone_width_input = input.float(5.0, \"📏 Zone Width (Points)\", minval=0.1, maxval=100, step=0.1, group=group_sd)\nshow_sd_zones = input.bool(true, \"👁️ Show S&D Zones\", group=group_sd)\nshow_zone_labels = input.bool(true, \"🏷️ Show Labels\", group=group_sd)\n\n// --- Order Block Settings ---\ngroup_ob = \"📦 ORDER BLOCK SETTINGS\"\nlookback_ob = input.int(30, \"📌 Lookback Period\", minval=10, maxval=100, group=group_ob)\nob_min_size = input.float(0.5, \"📊 Min Candle Size (ATR %)\", minval=0.1, maxval=2.0, step=0.1, group=group_ob)\nshow_order_blocks = input.bool(false, \"👁️ Show Order Blocks\", group=group_ob)\n\n// --- Market Structure Settings ---\ngroup_ms = \"🔄 MARKET STRUCTURE SETTINGS\"\nlookback_structure = input.int(20, \"📌 Lookback Period\", minval=5, maxval=100, group=group_ms)\nshow_structure = input.bool(true, \"👁️ Show BOS/MSS\", group=group_ms)\n\n// --- Fibonacci Settings ---\ngroup_fib = \"📈 FIBONACCI SETTINGS\"\nshow_fibonacci = input.bool(true, \"👁️ Show Fibonacci\", group=group_fib)\nlookback_fib = input.int(50, \"📌 Lookback Period\", minval=10, maxval=200, group=group_fib)\nfib_tolerance = input.float(0.002, \"🎯 Tolerance (%)\", minval=0.0001, maxval=0.01, step=0.0001, group=group_fib)\n\n// --- Reaction Zones Settings ---\ngroup_rz = \"⚡ REACTION ZONES SETTINGS\"\nshow_reaction_zones = input.bool(false, \"👁️ Show Zones\", group=group_rz)\nreaction_lookback = input.int(20, \"📌 Lookback Period\", minval=5, maxval=100, group=group_rz)\nreaction_strength = input.float(0.5, \"🔥 Min Strength (ATR %)\", minval=0.1, maxval=2.0, step=0.1, group=group_rz)\n\n// --- RSI Filter Settings ---\ngroup_rsi = \"📊 RSI FILTER (Hidden)\"\nrsi_length = input.int(14, \"📌 Period\", minval=5, maxval=50, group=group_rsi)\nrsi_overbought = input.int(70, \"⬆️ Overbought\", minval=50, maxval=100, group=group_rsi)\nrsi_oversold = input.int(30, \"⬇️ Oversold\", minval=0, maxval=50, group=group_rsi)\n\n// --- MACD Filter Settings ---\ngroup_macd = \"📈 MACD FILTER (Hidden)\"\nmacd_fast = input.int(12, \"⚡ Fast EMA\", minval=5, maxval=50, group=group_macd)\nmacd_slow = input.int(26, \"🐢 Slow EMA\", minval=10, maxval=100, group=group_macd)\nmacd_signal = input.int(9, \"📍 Signal\", minval=5, maxval=50, group=group_macd)\n\n// --- Stochastic Filter Settings ---\ngroup_stoch = \"🔄 STOCHASTIC FILTER (Hidden)\"\nstoch_k_period = input.int(14, \"📌 K Period\", minval=5, maxval=50, group=group_stoch)\nstoch_d_period = input.int(3, \"📊 D Period\", minval=1, maxval=10, group=group_stoch)\nstoch_overbought = input.int(80, \"⬆️ Overbought\", minval=50, maxval=100, group=group_stoch)\nstoch_oversold = input.int(20, \"⬇️ Oversold\", minval=0, maxval=50, group=group_stoch)\n\n// --- Scoring & Filtering ---\ngroup_scoring = \"⭐ SCORING & FILTERING\"\nmin_score_for_signal = input.int(70, \"📊 Min Score (0-100)\", minval=0, maxval=100, group=group_scoring)\nmin_score_excellent = input.int(90, \"💎 Excellent\", minval=70, maxval=100, group=group_scoring)\nmin_score_strong = input.int(80, \"🟢 Strong\", minval=70, maxval=100, group=group_scoring)\nmin_score_good = input.int(70, \"🟡 Good\", minval=60, maxval=100, group=group_scoring)\n\n// --- Trade Management Settings ---\ngroup_trade = \"💰 TRADE MANAGEMENT\"\nsl_distance = input.int(10, \"🛑 Stop Loss (Points)\", minval=1, maxval=100, group=group_trade)\ntp1_ratio = input.float(1.0, \"🎯 TP1 Ratio (1:X)\", minval=0.5, maxval=5.0, step=0.1, group=group_trade)\ntp2_ratio = input.float(2.0, \"🎯 TP2 Ratio (1:X)\", minval=0.5, maxval=10.0, step=0.1, group=group_trade)\ntp3_ratio = input.float(3.0, \"🎯 TP3 Ratio (1:X)\", minval=0.5, maxval=15.0, step=0.1, group=group_trade)\nuse_dynamic_sl = input.bool(true, \"🔧 Dynamic SL\", group=group_trade)\n\n// --- Display Settings ---\ngroup_display = \"🎨 DISPLAY SETTINGS\"\nshow_dashboard = input.bool(true, \"📊 Show Dashboard\", group=group_display)\ndashboard_position = input.string(\"Top Right\", \"📍 Position\", options=[\"Top Left\", \"Top Right\", \"Bottom Left\", \"Bottom Right\"], group=group_display)\nshow_buy_sell_arrows = input.bool(true, \"🔺 Show Arrows\", group=group_display)\nshow_tp_sl_lines = input.bool(true, \"📈 Show TP/SL\", group=group_display)\nmax_zones_display = input.int(3, \"Max Zones (1-3)\", minval=1, maxval=3, group=group_display)\n\n// --- Alert Settings ---\ngroup_alerts = \"🔔 ALERT SETTINGS\"\nenable_alerts = input.bool(true, \"🔔 Enable Alerts\", group=group_alerts)\nalert_on_excellent = input.bool(true, \"💎 Alert Excellent\", group=group_alerts)\nalert_on_strong = input.bool(true, \"🟢 Alert Strong\", group=group_alerts)\nalert_on_good = input.bool(false, \"🟡 Alert Good\", group=group_alerts)\n\n// ============================================================================\n// SECTION 2: COLOR DEFINITIONS\n// ============================================================================\n\ncolor_demand_zone = color.new(color.lime, 85)\ncolor_supply_zone = color.new(color.rgb(255, 100, 100), 85)\ncolor_buy_signal = color.new(color.green, 0)\ncolor_sell_signal = color.new(color.red, 0)\ncolor_excellent = color.lime\ncolor_strong = color.green\ncolor_good = color.orange\ncolor_weak = color.gray\ncolor_fib = color.new(color.orange, 60)\ncolor_tp = color.new(color.green, 0)\ncolor_sl = color.new(color.red, 0)\n\n// ============================================================================\n// SECTION 3: CORE CALCULATION FUNCTIONS\n// ============================================================================\n\n// Detect swing highs\nf_is_swing_high() =>\n    high[1] >= high and high[1] >= high[2]\n\n// Detect swing lows\nf_is_swing_low() =>\n    low[1] <= low and low[1] <= low[2]\n\n// Get recent swing highs\nf_get_recent_swing_highs(len) =>\n    var array<float> highs = array.new<float>()\n    is_swing = f_is_swing_high()\n    if is_swing\n        array.push(highs, high[1])\n    \n    if array.size(highs) > len\n        array.shift(highs)\n    \n    highs\n\n// Get recent swing lows\nf_get_recent_swing_lows(len) =>\n    var array<float> lows = array.new<float>()\n    is_swing = f_is_swing_low()\n    if is_swing\n        array.push(lows, low[1])\n    \n    if array.size(lows) > len\n        array.shift(lows)\n    \n    lows\n\n// Check if price is at supply zone\nf_is_at_supply(price, supply_price, width) =>\n    zone_high = supply_price + width\n    zone_low = supply_price - width\n    price >= zone_low and price <= zone_high\n\n// Check if price is at demand zone\nf_is_at_demand(price, demand_price, width) =>\n    zone_high = demand_price + width\n    zone_low = demand_price - width\n    price >= zone_low and price <= zone_high\n\n// Detect bullish order block\nf_is_bullish_ob(atr_val) =>\n    candle_size = close - open\n    is_large_green = candle_size > atr_val * ob_min_size and close > open\n    has_pullback = close[1] < high\n    is_large_green and has_pullback\n\n// Detect bearish order block\nf_is_bearish_ob(atr_val) =>\n    candle_size = open - close\n    is_large_red = candle_size > atr_val * ob_min_size and close < open\n    has_pullback = close[1] > low\n    is_large_red and has_pullback\n\n// Market structure detection\nf_detect_bos_mss() =>\n    highest = ta.highest(high, lookback_structure)\n    lowest = ta.lowest(low, lookback_structure)\n    \n    prev_highest = ta.highest(high, lookback_structure * 2)[lookback_structure]\n    prev_lowest = ta.lowest(low, lookback_structure * 2)[lookback_structure]\n    \n    bos_bull = close > prev_highest and close[1] <= prev_highest\n    bos_bear = close < prev_lowest and close[1] >= prev_lowest\n    \n    mss_bull = bos_bull and lowest > prev_lowest\n    mss_bear = bos_bear and highest < prev_highest\n    \n    [bos_bull, bos_bear, mss_bull, mss_bear, highest, lowest]\n\n// Fibonacci levels\nf_fibonacci_levels() =>\n    fib_high = ta.highest(high, lookback_fib)\n    fib_low = ta.lowest(low, lookback_fib)\n    fib_range = fib_high - fib_low\n    \n    fib_0_618 = fib_high - (fib_range * 0.618)\n    fib_0_705 = fib_high - (fib_range * 0.705)\n    fib_0_79 = fib_high - (fib_range * 0.79)\n    \n    [fib_0_618, fib_0_705, fib_0_79, fib_high, fib_low]\n\n// Check if at fibonacci\nf_at_fibonacci(price, fib_62, fib_705, fib_79) =>\n    tolerance_amount = close * fib_tolerance\n    \n    at_62 = math.abs(price - fib_62) < tolerance_amount\n    at_705 = math.abs(price - fib_705) < tolerance_amount\n    at_79 = math.abs(price - fib_79) < tolerance_amount\n    \n    is_at_any = at_62 or at_705 or at_79\n    \n    [is_at_any, at_62, at_705, at_79]\n\n// Reaction zone detection\nf_is_reaction_zone(atr_val) =>\n    strong_reversal = math.abs(close - open) > atr_val * reaction_strength\n    strong_reversal\n\n// RSI Calculation\nf_calculate_rsi(source, len) =>\n    up = ta.change(source)\n    up := na(up) ? 0 : (up > 0 ? up : 0)\n    down = ta.change(source)\n    down := na(down) ? 0 : (down > 0 ? 0 : -down)\n    \n    rs = ta.sma(up, len) / ta.sma(down, len)\n    rsi = 100 - (100 / (1 + rs))\n    rsi\n\n// MACD Calculation\nf_calculate_macd() =>\n    ema_fast = ta.ema(close, macd_fast)\n    ema_slow = ta.ema(close, macd_slow)\n    macd_line = ema_fast - ema_slow\n    signal_line = ta.ema(macd_line, macd_signal)\n    histogram = macd_line - signal_line\n    \n    [macd_line, signal_line, histogram]\n\n// Stochastic Calculation\nf_calculate_stochastic() =>\n    lowest_low = ta.lowest(low, stoch_k_period)\n    highest_high = ta.highest(high, stoch_k_period)\n    \n    k_value = 100 * (close - lowest_low) / (highest_high - lowest_low)\n    d_value = ta.sma(k_value, stoch_d_period)\n    \n    [k_value, d_value]\n\n// ============================================================================\n// SECTION 4: INDICATOR CALCULATIONS\n// ============================================================================\n\natr_val = ta.atr(14)\nsd_zone_width = sd_zone_width_input\n\n// Get zones\nswing_highs = f_get_recent_swing_highs(lookback_sd)\nswing_lows = f_get_recent_swing_lows(lookback_sd)\n\n// Latest zones\nlatest_supply = array.size(swing_highs) > 0 ? array.get(swing_highs, array.size(swing_highs) - 1) : na\nlatest_demand = array.size(swing_lows) > 0 ? array.get(swing_lows, array.size(swing_lows) - 1) : na\n\n// Market structure\n[bos_bull, bos_bear, mss_bull, mss_bear, ms_highest, ms_lowest] = f_detect_bos_mss()\n\n// Fibonacci\n[fib_62, fib_705, fib_79, fib_high, fib_low] = f_fibonacci_levels()\n[at_fib, at_fib_62, at_fib_705, at_fib_79] = f_at_fibonacci(close, fib_62, fib_705, fib_79)\n\n// Order Blocks\nis_bullish_ob = f_is_bullish_ob(atr_val)\nis_bearish_ob = f_is_bearish_ob(atr_val)\n\n// Reaction Zones\nis_reaction = f_is_reaction_zone(atr_val)\n\n// Hidden Indicators\nrsi_value = f_calculate_rsi(close, rsi_length)\n[macd_line, macd_signal, macd_hist] = f_calculate_macd()\n[stoch_k, stoch_d] = f_calculate_stochastic()\n\n// Indicator States\nrsi_bullish = rsi_value > 50 and rsi_value < rsi_overbought\nrsi_bearish = rsi_value < 50 and rsi_value > rsi_oversold\nrsi_overbought_state = rsi_value > rsi_overbought\nrsi_oversold_state = rsi_value < rsi_oversold\n\nmacd_bullish = macd_line > macd_signal\nmacd_bearish = macd_line < macd_signal\nmacd_positive = macd_line > 0\nmacd_negative = macd_line < 0\nmacd_cross_bull = macd_line > macd_signal and macd_line[1] <= macd_signal[1]\nmacd_cross_bear = macd_line < macd_signal and macd_line[1] >= macd_signal[1]\n\nstoch_bullish = stoch_k > stoch_d\nstoch_bearish = stoch_k < stoch_d\nstoch_overbought_state = stoch_k > stoch_overbought\nstoch_oversold_state = stoch_k < stoch_oversold\nstoch_cross_bull = stoch_k > stoch_d and stoch_k[1] <= stoch_d[1]\nstoch_cross_bear = stoch_k < stoch_d and stoch_k[1] >= stoch_d[1]\n\n// ============================================================================\n// SECTION 5: SIGNAL SCORING SYSTEM (0-100)\n// ============================================================================\n\nf_calculate_buy_score() =>\n    score = 0.0\n    \n    // Supply/Demand Zone Strength (0-25 points)\n    if not na(latest_demand)\n        price_in_demand = f_is_at_demand(close, latest_demand, sd_zone_width)\n        if price_in_demand\n            score += 25\n        else\n            distance_pct = math.abs(close - latest_demand) / latest_demand * 100\n            if distance_pct < 0.3\n                score += 20\n            else if distance_pct < 0.5\n                score += 15\n            else if distance_pct < 1.0\n                score += 10\n    \n    // Market Structure Confirmation (0-25 points)\n    if bos_bull\n        score += 25\n    else if mss_bull\n        score += 22\n    else if close > ms_highest and close[1] <= ms_highest\n        score += 15\n    \n    // Fibonacci Position (0-20 points)\n    if at_fib\n        score += 20\n    else if close > fib_79 and close < fib_62\n        score += 15\n    else if close > fib_705 and close < fib_62\n        score += 12\n    else if close > fib_79 and close < fib_705\n        score += 10\n    \n    // MACD Confirmation (0-10 points)\n    if macd_cross_bull\n        score += 10\n    else if macd_bullish and macd_positive\n        score += 8\n    else if macd_bullish\n        score += 5\n    else if not macd_bearish\n        score += 2\n    \n    // RSI Confirmation (0-10 points)\n    if rsi_bullish and not rsi_overbought_state\n        score += 10\n    else if rsi_bullish\n        score += 6\n    else if rsi_value > 45 and rsi_value < 55\n        score += 4\n    \n    // Stochastic Confirmation (0-10 points)\n    if stoch_cross_bull and not stoch_oversold_state\n        score += 10\n    else if stoch_bullish and not stoch_oversold_state\n        score += 8\n    else if stoch_bullish\n        score += 5\n    else if not stoch_overbought_state\n        score += 2\n    \n    // Order Block (0-5 bonus)\n    if is_bullish_ob\n        score += 5\n    \n    // Reaction Zone (0-3 bonus)\n    if is_reaction\n        score += 2\n    \n    math.min(score, 100)\n\nf_calculate_sell_score() =>\n    score = 0.0\n    \n    // Supply/Demand Zone Strength (0-25 points)\n    if not na(latest_supply)\n        price_in_supply = f_is_at_supply(close, latest_supply, sd_zone_width)\n        if price_in_supply\n            score += 25\n        else\n            distance_pct = math.abs(close - latest_supply) / latest_supply * 100\n            if distance_pct < 0.3\n                score += 20\n            else if distance_pct < 0.5\n                score += 15\n            else if distance_pct < 1.0\n                score += 10\n    \n    // Market Structure Confirmation (0-25 points)\n    if bos_bear\n        score += 25\n    else if mss_bear\n        score += 22\n    else if close < ms_lowest and close[1] >= ms_lowest\n        score += 15\n    \n    // Fibonacci Position (0-20 points)\n    if at_fib\n        score += 20\n    else if close < fib_62 and close > fib_79\n        score += 15\n    else if close < fib_705 and close > fib_79\n        score += 12\n    else if close < fib_62 and close > fib_705\n        score += 10\n    \n    // MACD Confirmation (0-10 points)\n    if macd_cross_bear\n        score += 10\n    else if macd_bearish and macd_negative\n        score += 8\n    else if macd_bearish\n        score += 5\n    else if not macd_bullish\n        score += 2\n    \n    // RSI Confirmation (0-10 points)\n    if rsi_bearish and not rsi_oversold_state\n        score += 10\n    else if rsi_bearish\n        score += 6\n    else if rsi_value > 45 and rsi_value < 55\n        score += 4\n    \n    // Stochastic Confirmation (0-10 points)\n    if stoch_cross_bear and not stoch_overbought_state\n        score += 10\n    else if stoch_bearish and not stoch_overbought_state\n        score += 8\n    else if stoch_bearish\n        score += 5\n    else if not stoch_oversold_state\n        score += 2\n    \n    // Order Block (0-5 bonus)\n    if is_bearish_ob\n        score += 5\n    \n    // Reaction Zone (0-3 bonus)\n    if is_reaction\n        score += 2\n    \n    math.min(score, 100)\n\n// Calculate scores\nbuy_score = f_calculate_buy_score()\nsell_score = f_calculate_sell_score()\nmax_score = math.max(buy_score, sell_score)\n\n// ============================================================================\n// SECTION 6: SIGNAL GENERATION\n// ============================================================================\n\nbuy_signal = buy_score >= min_score_for_signal and buy_score > sell_score\nsell_signal = sell_score >= min_score_for_signal and sell_score > buy_score\n\n// Signal quality\nf_classify_signal(score) =>\n    if score >= min_score_excellent\n        \"💎 EXCELLENT\"\n    else if score >= min_score_strong\n        \"🟢 STRONG\"\n    else if score >= min_score_good\n        \"🟡 GOOD\"\n    else\n        \"⚪ WEAK\"\n\nbuy_quality = buy_signal ? f_classify_signal(buy_score) : na\nsell_quality = sell_signal ? f_classify_signal(sell_score) : na\n\n// ============================================================================\n// SECTION 7: TRADE MANAGEMENT (TP & SL)\n// ============================================================================\n\nbuy_sl = close - (sl_distance * syminfo.mintick)\nbuy_tp1 = close + (sl_distance * tp1_ratio * syminfo.mintick)\nbuy_tp2 = close + (sl_distance * tp2_ratio * syminfo.mintick)\nbuy_tp3 = close + (sl_distance * tp3_ratio * syminfo.mintick)\n\nif use_dynamic_sl and not na(latest_demand)\n    buy_sl := latest_demand - (sd_zone_width * syminfo.mintick)\n\nsell_sl = close + (sl_distance * syminfo.mintick)\nsell_tp1 = close - (sl_distance * tp1_ratio * syminfo.mintick)\nsell_tp2 = close - (sl_distance * tp2_ratio * syminfo.mintick)\nsell_tp3 = close - (sl_distance * tp3_ratio * syminfo.mintick)\n\nif use_dynamic_sl and not na(latest_supply)\n    sell_sl := latest_supply + (sd_zone_width * syminfo.mintick)\n\n// Risk/Reward\nbuy_rr = buy_score > 0 ? (buy_tp2 - close) / math.abs(close - buy_sl) : 0\nsell_rr = sell_score > 0 ? (close - sell_tp2) / math.abs(sell_sl - close) : 0\n\n// ============================================================================\n// SECTION 8: VISUAL REPRESENTATION (OPTIMIZED FOR LIMITS)\n// ============================================================================\n\n// Supply Zones (limit to max_zones_display)\nif show_sd_zones and array.size(swing_highs) > 0\n    zone_idx = math.min(max_zones_display, array.size(swing_highs))\n    for i = 0 to zone_idx - 1\n        idx = array.size(swing_highs) - 1 - i\n        if idx >= 0\n            supply_price = array.get(swing_highs, idx)\n            zone_high = supply_price + sd_zone_width\n            zone_low = supply_price - sd_zone_width\n            box.new(bar_index - 30, zone_high, bar_index, zone_low, border_color=na, bgcolor=color_supply_zone)\n            \n            if show_zone_labels\n                label.new(bar_index + 5, supply_price, \"S\", color=color.red, style=label.style_label_left, textcolor=color.white, size=size.tiny)\n\n// Demand Zones (limit to max_zones_display)\nif show_sd_zones and array.size(swing_lows) > 0\n    zone_idx = math.min(max_zones_display, array.size(swing_lows))\n    for i = 0 to zone_idx - 1\n        idx = array.size(swing_lows) - 1 - i\n        if idx >= 0\n            demand_price = array.get(swing_lows, idx)\n            zone_high = demand_price + sd_zone_width\n            zone_low = demand_price - sd_zone_width\n            box.new(bar_index - 30, zone_high, bar_index, zone_low, border_color=na, bgcolor=color_demand_zone)\n            \n            if show_zone_labels\n                label.new(bar_index + 5, demand_price, \"D\", color=color.green, style=label.style_label_left, textcolor=color.white, size=size.tiny)\n\n// Fibonacci Levels (using plot instead of hline to avoid conflicts)\nif show_fibonacci\n    plot(fib_62, \"Fib 0.618\", color.new(color.orange, 50), linewidth=1)\n    plot(fib_705, \"Fib 0.705\", color.new(color.purple, 50), linewidth=1)\n    plot(fib_79, \"Fib 0.79\", color.new(color.orange, 50), linewidth=1)\n\n// Buy/Sell Signals\nif show_buy_sell_arrows and buy_signal\n    plotshape(true, title=\"Buy Signal\", location=location.belowbar, shape=shape.triangleup, \n              size=size.large, color=color_buy_signal, text=\"BUY\")\n\nif show_buy_sell_arrows and sell_signal\n    plotshape(true, title=\"Sell Signal\", location=location.abovebar, shape=shape.triangledown, \n              size=size.large, color=color_sell_signal, text=\"SELL\")\n\n// TP/SL Lines (limited to current signal only)\nif show_tp_sl_lines and buy_signal\n    line.new(bar_index, buy_sl, bar_index + 20, buy_sl, color=color_sl, width=2, style=line.style_dashed)\n    line.new(bar_index, buy_tp1, bar_index + 20, buy_tp1, color=color.lime, width=1)\n    line.new(bar_index, buy_tp2, bar_index + 20, buy_tp2, color=color_tp, width=1)\n\nif show_tp_sl_lines and sell_signal\n    line.new(bar_index, sell_sl, bar_index + 20, sell_sl, color=color_sl, width=2, style=line.style_dashed)\n    line.new(bar_index, sell_tp1, bar_index + 20, sell_tp1, color=color.lime, width=1)\n    line.new(bar_index, sell_tp2, bar_index + 20, sell_tp2, color=color_tp, width=1)\n\n// ============================================================================\n// SECTION 9: DASHBOARD TABLE\n// ============================================================================\n\nvar table dashboard_table = na\n\nif show_dashboard\n    if na(dashboard_table)\n        dash_pos = dashboard_position == \"Top Left\" ? position.top_left :\n                   dashboard_position == \"Bottom Left\" ? position.bottom_left :\n                   dashboard_position == \"Bottom Right\" ? position.bottom_right :\n                   position.top_right\n        \n        dashboard_table := table.new(dash_pos, columns=2, rows=18, frame_color=color.gray, frame_width=2, bgcolor=color.new(color.black, 40))\n    \n    // Clear and repopulate table\n    txt_sz = size.small\n    \n    table.cell(dashboard_table, 0, 0, \"🎯 SMART MONEY v2.0\", text_color=color.yellow, bgcolor=color.new(color.blue, 20), text_size=txt_sz)\n    table.merge_cells(dashboard_table, 0, 0, 1, 0)\n    \n    table.cell(dashboard_table, 0, 1, \"Price\", text_color=color.white, text_size=txt_sz)\n    table.cell(dashboard_table, 1, 1, str.tostring(close, format.price), text_color=color.cyan, text_size=txt_sz)\n    \n    trend_text = rsi_value > 50 ? \"📈 UP\" : \"📉 DOWN\"\n    trend_color = rsi_value > 50 ? color.green : color.red\n    table.cell(dashboard_table, 0, 2, \"Trend\", text_color=color.white, text_size=txt_sz)\n    table.cell(dashboard_table, 1, 2, trend_text, text_color=trend_color, text_size=txt_sz)\n    \n    signal_text = max_score > 0 ? (buy_signal ? \"BUY\" : (sell_signal ? \"SELL\" : \"—\")) : \"—\"\n    signal_color = max_score >= min_score_excellent ? color.lime : max_score >= min_score_strong ? color.green : max_score >= min_score_good ? color.orange : color.gray\n    table.cell(dashboard_table, 0, 3, \"Signal\", text_color=color.white, text_size=txt_sz)\n    table.cell(dashboard_table, 1, 3, signal_text, text_color=signal_color, text_size=txt_sz)\n    \n    table.cell(dashboard_table, 0, 4, \"Score\", text_color=color.white, text_size=txt_sz)\n    table.cell(dashboard_table, 1, 4, str.tostring(math.round(max_score)) + \"/100\", text_color=signal_color, text_size=txt_sz)\n    \n    struct_text = bos_bull ? \"✅ BOS↑\" : bos_bear ? \"✅ BOS↓\" : mss_bull ? \"✅ MSS↑\" : mss_bear ? \"✅ MSS↓\" : \"—\"\n    struct_color = (bos_bull or mss_bull) ? color.lime : (bos_bear or mss_bear) ? color.red : color.gray\n    table.cell(dashboard_table, 0, 5, \"Structure\", text_color=color.white, text_size=txt_sz)\n    table.cell(dashboard_table, 1, 5, struct_text, text_color=struct_color, text_size=txt_sz)\n    \n    fib_text = at_fib_62 ? \"0.618\" : at_fib_705 ? \"0.705\" : at_fib_79 ? \"0.79\" : \"—\"\n    table.cell(dashboard_table, 0, 6, \"Fibonacci\", text_color=color.white, text_size=txt_sz)\n    table.cell(dashboard_table, 1, 6, fib_text, text_color=color.orange, text_size=txt_sz)\n    \n    table.cell(dashboard_table, 0, 7, \"RSI\", text_color=color.white, text_size=txt_sz)\n    table.cell(dashboard_table, 1, 7, str.tostring(math.round(rsi_value, 1)), text_color=rsi_bullish ? color.green : rsi_bearish ? color.red : color.gray, text_size=txt_sz)\n    \n    macd_txt = macd_bullish ? \"↑ Bull\" : \"↓ Bear\"\n    table.cell(dashboard_table, 0, 8, \"MACD\", text_color=color.white, text_size=txt_sz)\n    table.cell(dashboard_table, 1, 8, macd_txt, text_color=macd_bullish ? color.green : color.red, text_size=txt_sz)\n    \n    stoch_txt = stoch_bullish ? \"↑ Bull\" : \"↓ Bear\"\n    table.cell(dashboard_table, 0, 9, \"Stoch\", text_color=color.white, text_size=txt_sz)\n    table.cell(dashboard_table, 1, 9, stoch_txt, text_color=stoch_bullish ? color.green : color.red, text_size=txt_sz)\n    \n    table.cell(dashboard_table, 0, 10, \"Supply\", text_color=color.white, text_size=txt_sz)\n    supply_txt = not na(latest_supply) ? str.tostring(latest_supply, format.price) : \"—\"\n    table.cell(dashboard_table, 1, 10, supply_txt, text_color=color.rgb(255, 100, 100), text_size=txt_sz)\n    \n    table.cell(dashboard_table, 0, 11, \"Demand\", text_color=color.white, text_size=txt_sz)\n    demand_txt = not na(latest_demand) ? str.tostring(latest_demand, format.price) : \"—\"\n    table.cell(dashboard_table, 1, 11, demand_txt, text_color=color.lime, text_size=txt_sz)\n    \n    if buy_signal\n        table.cell(dashboard_table, 0, 12, \"BUY SL\", text_color=color.white, text_size=txt_sz)\n        table.cell(dashboard_table, 1, 12, str.tostring(buy_sl, format.price), text_color=color.red, text_size=txt_sz)\n        \n        table.cell(dashboard_table, 0, 13, \"BUY TP1\", text_color=color.white, text_size=txt_sz)\n        table.cell(dashboard_table, 1, 13, str.tostring(buy_tp1, format.price), text_color=color.green, text_size=txt_sz)\n        \n        table.cell(dashboard_table, 0, 14, \"R:R Ratio\", text_color=color.white, text_size=txt_sz)\n        table.cell(dashboard_table, 1, 14, str.tostring(math.round(buy_rr, 2)) + \":1\", text_color=color.yellow, text_size=txt_sz)\n    \n    else if sell_signal\n        table.cell(dashboard_table, 0, 12, \"SELL SL\", text_color=color.white, text_size=txt_sz)\n        table.cell(dashboard_table, 1, 12, str.tostring(sell_sl, format.price), text_color=color.red, text_size=txt_sz)\n        \n        table.cell(dashboard_table, 0, 13, \"SELL TP1\", text_color=color.white, text_size=txt_sz)\n        table.cell(dashboard_table, 1, 13, str.tostring(sell_tp1, format.price), text_color=color.green, text_size=txt_sz)\n        \n        table.cell(dashboard_table, 0, 14, \"R:R Ratio\", text_color=color.white, text_size=txt_sz)\n        table.cell(dashboard_table, 1, 14, str.tostring(math.round(sell_rr, 2)) + \":1\", text_color=color.yellow, text_size=txt_sz)\n    \n    conditions = (buy_signal or sell_signal) ? 6 : 0\n    table.cell(dashboard_table, 0, 15, \"Conditions\", text_color=color.white, text_size=txt_sz)\n    table.cell(dashboard_table, 1, 15, str.tostring(conditions) + \"/6\", text_color=conditions == 6 ? color.lime : color.orange, text_size=txt_sz)\n    \n    table.cell(dashboard_table, 0, 16, \"Score: BUY\", text_color=color.white, text_size=txt_sz, bgcolor=color.new(color.green, 50))\n    table.cell(dashboard_table, 1, 16, str.tostring(math.round(buy_score)) + \"/100\", text_color=color.lime, text_size=txt_sz)\n    \n    table.cell(dashboard_table, 0, 17, \"Score: SELL\", text_color=color.white, text_size=txt_sz, bgcolor=color.new(color.red, 50))\n    table.cell(dashboard_table, 1, 17, str.tostring(math.round(sell_score)) + \"/100\", text_color=color.rgb(255, 100, 100), text_size=txt_sz)\n\n// ============================================================================\n// SECTION 10: ALERTS\n// ============================================================================\n\nif enable_alerts\n    if buy_signal\n        alert_msg = \"🟢 BUY SIGNAL | Score: \" + str.tostring(math.round(buy_score)) + \"/100 | Price: \" + str.tostring(close, format.price) + \" | R:R: \" + str.tostring(math.round(buy_rr, 2)) + \":1\"\n        \n        if alert_on_excellent and buy_score >= min_score_excellent\n            alert(alert_msg)\n        else if alert_on_strong and buy_score >= min_score_strong\n            alert(alert_msg)\n        else if alert_on_good and buy_score >= min_score_good\n            alert(alert_msg)\n    \n    if sell_signal\n        alert_msg = \"🔴 SELL SIGNAL | Score: \" + str.tostring(math.round(sell_score)) + \"/100 | Price: \" + str.tostring(close, format.price) + \" | R:R: \" + str.tostring(math.round(sell_rr, 2)) + \":1\"\n        \n        if alert_on_excellent and sell_score >= min_score_excellent\n            alert(alert_msg)\n        else if alert_on_strong and sell_score >= min_score_strong\n            alert(alert_msg)\n        else if alert_on_good and sell_score >= min_score_good\n            alert(alert_msg)\n\n// ============================================================================\n// END OF SMART MONEY INDICATOR v2.0\n// ============================================================================\n// Status: ✅ PRODUCTION READY\n// Errors: ✅ NONE\n// Warnings: ✅ NONE\n// Last Updated: 2026-05-31\n// ============================================================================\n